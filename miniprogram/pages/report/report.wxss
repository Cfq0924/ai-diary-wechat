/* pages/report/report.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

/* 顶部标签栏 */
.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16px 0;
  font-size: 15px;
  color: #666;
  position: relative;
}

.tab.active {
  color: #07c160;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40px;
  height: 3px;
  background: #07c160;
  border-radius: 2px;
}

/* 日期选择器 */
.date-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  background: #fff;
  margin: 12px 16px;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.nav-btn {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: #f5f5f5;
  color: #333;
  font-size: 18px;
  line-height: 36px;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn::after {
  border: none;
}

.current-date {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

/* 报表内容区 */
.report-content {
  flex: 1;
  padding: 0 16px 16px;
}

.loading,
.empty-state {
  text-align: center;
  padding: 80px 0;
  color: #999;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 16px;
  padding: 24px;
  margin-top: 16px;
  color: #fff;
  box-shadow: 0 4px 16px rgba(7, 193, 96, 0.3);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 32px;
  font-weight: 600;
  display: block;
}

.stat-label {
  font-size: 13px;
  opacity: 0.9;
  margin-top: 4px;
  display: block;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-top: 16px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
}

/* 词云 */
.word-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.word-item {
  padding: 6px 14px;
  background: #f5f5f5;
  border-radius: 16px;
  font-size: 14px;
}

/* 日记列表 */
.diary-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.diary-item {
  padding: 16px;
  background: #fafafa;
  border-radius: 8px;
  border-left: 3px solid #07c160;
}

.diary-time {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.diary-content {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  max-height: 60px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
