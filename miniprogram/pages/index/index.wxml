<!-- 首页 - 时间线 -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-top">
      <text class="title">我的日记</text>
      <view class="header-actions">
        <view class="action-btn" bindtap="goToTags">
          <text class="action-icon">🏷️</text>
        </view>
        <view class="report-btn" bindtap="goToReport">
          <text class="report-icon">📊</text>
          <text class="report-text">报表</text>
        </view>
      </view>
    </view>
    <text class="subtitle">{{today}}</text>
  </view>

  <!-- 日记列表 -->
  <view class="diary-list">
    <view wx:if="{{diaryList.length === 0}}" class="empty-state">
      <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
      <text class="empty-text">还没有日记，开始记录吧</text>
    </view>

    <view wx:for="{{diaryList}}" wx:key="_id" class="diary-item" bindtap="goToDetail" data-id="{{item._id}}">
      <view class="diary-content">{{item.content}}</view>
      <view class="diary-tags" wx:if="{{item.autoTags && item.autoTags.length > 0}}">
        <text wx:for="{{item.autoTags}}" wx:key="name" wx:for-item="tagItem" class="tag-small" style="color: {{tagItem.style.color}}; background: {{tagItem.style.background}}" catchtap="searchByTag" data-tag="{{tagItem.name}}" bindlongpress="showTagMenu" data-tag="{{tagItem.name}}" data-diary-id="{{item._id}}">{{tagItem.name}}</text>
      </view>
      <view class="diary-meta">
        <text class="diary-date">{{item.dateStr}}</text>
        <text class="diary-count">{{item.wordCount}}字</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:if="{{!hasMore && diaryList.length > 0}}" class="no-more">没有更多了</view>
</view>

<!-- 悬浮按钮 -->
<button class="fab-btn" bindtap="goToEdit">+</button>

<!-- 标签操作菜单 -->
<view wx:if="{{showMenu}}" class="menu-overlay" bindtap="hideMenu"></view>
<view wx:if="{{showMenu}}" class="action-menu" style="bottom: {{menuBottom}}px">
  <view class="menu-item" bindtap="searchByTagFromMenu">搜索该标签</view>
  <view class="menu-item" bindtap="manageTagInPage">管理此标签</view>
  <view class="menu-cancel" bindtap="hideMenu">取消</view>
</view>
