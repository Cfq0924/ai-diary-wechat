/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background: #f6f6f6;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 40px;
  padding: 0 16px;
  background: #f5f5f5;
  border-radius: 20px;
  font-size: 14px;
}

.clear-btn {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  background: #e0e0e0;
  color: #666;
  font-size: 20px;
  line-height: 32px;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn::after {
  border: none;
}

/* 搜索结果 */
.result-section {
  padding: 16px;
}

.searching-tag {
  margin-bottom: 12px;
  padding: 8px 12px;
  background: #e8f5e9;
  border-radius: 8px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.tag-label {
  font-size: 13px;
  color: #666;
}

.tag-name {
  font-size: 14px;
  color: #07c160;
  font-weight: 500;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.result-info {
  font-size: 13px;
  color: #999;
  margin-bottom: 8px;
}

.result-item {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.result-content {
  font-size: 15px;
  color: #333;
  line-height: 1.6;
  max-height: 60px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.result-meta {
  margin-top: 12px;
}

.result-date {
  font-size: 12px;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 80px 0;
}

.empty-text {
  color: #999;
  font-size: 14px;
}

/* 搜索提示 */
.search-tips {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: calc(100vh - 100px);
}

.tip-title {
  font-size: 16px;
  color: #666;
  margin-bottom: 8px;
}

.tip-desc {
  font-size: 13px;
  color: #999;
}

.tip-desc-small {
  font-size: 12px;
  color: #bbb;
  margin-top: 4px;
}

/* 语义搜索开关 */
.semantic-search-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.toggle-label {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.toggle-desc {
  font-size: 12px;
  color: #07c160;
}

.similarity-score {
  font-size: 12px;
  color: #07c160;
  margin-left: 8px;
  padding: 2px 6px;
  background: #e8f5e9;
  border-radius: 4px;
}

.search-mode-hint {
  color: #999;
  font-size: 13px;
}
