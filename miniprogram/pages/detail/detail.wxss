/* pages/detail/detail.wxss */
.container {
  padding: 20px;
  padding-bottom: 80px;
}

.diary-content {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  font-size: 16px;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.meta-info {
  margin-top: 20px;
  background: #fff;
  border-radius: 12px;
  padding: 16px 20px;
}

.meta-item {
  display: flex;
  align-items: center;
  padding: 8px 0;
}

.meta-item:not(:last-child) {
  border-bottom: 1px solid #f0f0f0;
}

.meta-label {
  width: 80px;
  font-size: 13px;
  color: #999;
}

.meta-value {
  font-size: 14px;
  color: #333;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag {
  background: #e8f5e9;
  color: #07c160;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 12px;
  padding: 12px;
  font-size: 14px;
  color: #333;
}

.action-btn.danger {
  border-color: #ffebee;
  color: #f44336;
}

.action-btn .icon {
  font-size: 16px;
}

.action-btn::after {
  border: none;
}
