<!-- 详情页面 -->
<view class="container">
  <view class="diary-content">
    <text>{{content}}</text>
  </view>

  <view class="meta-info">
    <view class="meta-item">
      <text class="meta-label">创建时间</text>
      <text class="meta-value">{{createdAt}}</text>
    </view>
    <view class="meta-item">
      <text class="meta-label">字数</text>
      <text class="meta-value">{{wordCount}}字</text>
    </view>
    <view class="meta-item" wx:if="{{autoTags && autoTags.length > 0}}">
      <text class="meta-label">标签</text>
      <view class="tags">
        <text wx:for="{{autoTags}}" wx:key="name" class="tag" style="color: {{item.style.color}}; background: {{item.style.background}}" catchtap="searchByTag" data-tag="{{item.name}}">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 相关日记 -->
  <view wx:if="{{relatedDiaries.length > 0}}" class="related-section">
    <view class="section-title">相关日记</view>
    <view class="related-list">
      <view wx:for="{{relatedDiaries}}" wx:key="_id" class="related-item" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="related-content">{{item.content}}</view>
        <view class="related-meta">
          <text class="related-date">{{item.dateStr}}</text>
          <text class="related-tag" wx:if="{{item.commonTag}}" style="color: {{item.commonTagStyle.color}}; background: {{item.commonTagStyle.background}}">#{{item.commonTag}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="actions">
    <button class="action-btn" bindtap="goToEdit">
      <text class="icon">✏️</text>
      <text>编辑</text>
    </button>
    <button class="action-btn danger" bindtap="deleteDiary">
      <text class="icon">🗑️</text>
      <text>删除</text>
    </button>
  </view>
</view>
