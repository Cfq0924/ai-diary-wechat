/* 标签管理页面 */
.container {
  padding: 16px;
  padding-bottom: 80px;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.3);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 28px;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4px;
}

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12px;
  padding: 8px 12px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  font-size: 14px;
  padding: 8px 0;
}

.clear-btn {
  width: 28px;
  height: 28px;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #999;
  padding: 0;
  margin: 0;
  line-height: 28px;
}

.clear-btn::after {
  border: none;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.section-count {
  font-size: 12px;
  color: #999;
}

/* 标签云 */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
}

.tag-name {
  font-weight: 500;
}

.tag-count {
  font-size: 11px;
  background: rgba(0, 0, 0, 0.1);
  padding: 2px 6px;
  border-radius: 8px;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tag-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: #fafafa;
  border-radius: 8px;
}

.tag-row-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.tag-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.tag-row-name {
  font-size: 14px;
  color: #333;
}

.tag-row-count {
  font-size: 12px;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding: 40px 0;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

/* 操作菜单 */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
}

.action-menu {
  position: fixed;
  left: 20px;
  right: 20px;
  bottom: 100px;
  background: #fff;
  border-radius: 16px;
  padding: 8px 0;
  z-index: 999;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
}

.menu-item {
  padding: 16px 20px;
  font-size: 16px;
  color: #333;
  text-align: center;
}

.menu-item.danger {
  color: #f44336;
}

.menu-cancel {
  padding: 16px 20px;
  font-size: 16px;
  color: #999;
  text-align: center;
  margin-top: 8px;
  border-top: 1px solid #f0f0f0;
}
